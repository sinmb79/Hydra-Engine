          "conditions": [
            {
              "leftValue": "={{ $json.shouldAutoKillSwitch }}",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              },
              "rightValue": ""
            }
          ]
        },
        "options": {}
      },
      "id": "f515cbf7-6a71-4f13-8d70-bb37c080f38a",
      "name": "Auto Kill Switch?",
