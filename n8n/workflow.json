        }
      },
      "id": "85d6186e-1f1c-44b1-bc94-f638dfeb1883",
      "name": "Trigger Kill Switch",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1280,
        180
      ],
