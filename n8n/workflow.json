        "text": "={{ $json.text }}"
      },
      "id": "744fe80a-6d16-4310-8b97-52b6e36d0a69",
      "name": "Send Kill Result",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1720,
        180
      ]
    }
